{
  "info": {
    "name": "RBAC Platform API",
    "description": "Authentication, RBAC administration, and audit endpoints for the RBAC platform. Set the {{base_url}} (default http://localhost:8000) and run Register or Login first to populate {{access_token}} / {{refresh_token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/register/", "host": ["{{base_url}}"], "path": ["api", "auth", "register", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"password\": \"Testpass123!\",\n  \"password_confirm\": \"Testpass123!\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var d = pm.response.json();",
                  "if (d.access) pm.collectionVariables.set('access_token', d.access);",
                  "if (d.refresh) pm.collectionVariables.set('refresh_token', d.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/login/", "host": ["{{base_url}}"], "path": ["api", "auth", "login", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@1234!\"\n}" }
          }
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["api", "auth", "token", "refresh", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/auth/profile/", "host": ["{{base_url}}"], "path": ["api", "auth", "profile", ""] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/logout/", "host": ["{{base_url}}"], "path": ["api", "auth", "logout", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" }
          }
        }
      ]
    },
    {
      "name": "RBAC",
      "item": [
        {
          "name": "List permissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/rbac/permissions/", "host": ["{{base_url}}"], "path": ["api", "rbac", "permissions", ""] }
          }
        },
        {
          "name": "Sync permissions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/rbac/permissions/sync/", "host": ["{{base_url}}"], "path": ["api", "rbac", "permissions", "sync", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"prune\": false\n}" }
          }
        },
        {
          "name": "List roles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/rbac/roles/", "host": ["{{base_url}}"], "path": ["api", "rbac", "roles", ""] }
          }
        },
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/rbac/users/", "host": ["{{base_url}}"], "path": ["api", "rbac", "users", ""] }
          }
        },
        {
          "name": "Assign roles to user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/rbac/users/1/assign-roles/", "host": ["{{base_url}}"], "path": ["api", "rbac", "users", "1", "assign-roles", ""] },
            "body": { "mode": "raw", "raw": "{\n  \"role_ids\": [2],\n  \"replace\": false\n}" }
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/audit/logs/", "host": ["{{base_url}}"], "path": ["api", "audit", "logs", ""] }
          }
        },
        {
          "name": "Export logs (CSV)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/audit/logs/export/", "host": ["{{base_url}}"], "path": ["api", "audit", "logs", "export", ""] }
          }
        },
        {
          "name": "Summary report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/audit/reports/summary/", "host": ["{{base_url}}"], "path": ["api", "audit", "reports", "summary", ""] }
          }
        },
        {
          "name": "Login-failures report",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/audit/reports/login-failures/", "host": ["{{base_url}}"], "path": ["api", "audit", "reports", "login-failures", ""] }
          }
        }
      ]
    }
  ]
}
